# =============================================================================
# SoroTrace API - Environment Variables
# Copy this file to .env and fill in the values before running the app.
# =============================================================================

# --- Server ---

# Port the NestJS server listens on (optional, defaults to 3001)
PORT=3001

# Node environment: development | test | production
NODE_ENV=development

# --- Database ---

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sorotrace

# --- Cache / Queue ---

# Redis connection URL used by BullMQ and caching (required)
REDIS_URL=redis://localhost:6379

# --- Stellar Network ---

# Target network: testnet | mainnet (required)
STELLAR_NETWORK=testnet

# Horizon REST API base URL (required)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint (required)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# --- Authentication ---

# Secret used to sign JWT tokens — REPLACE THIS with a long random string (required)
JWT_SECRET=REPLACE_THIS_WITH_A_LONG_RANDOM_SECRET

# JWT token expiry duration (optional, defaults to 7d)
JWT_EXPIRY=7d
