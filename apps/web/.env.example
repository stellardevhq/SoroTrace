# =============================================================================
# SoroTrace Web - Environment Variables
# Copy this file to .env and fill in the values before running the app.
# All NEXT_PUBLIC_* variables are exposed to the browser bundle.
# =============================================================================

# Base URL of the SoroTrace API (required)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL for real-time contract monitoring (required)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Stellar network the UI connects to: testnet | mainnet (required)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Canonical public URL of this web app, used for redirects and metadata (required)
NEXT_PUBLIC_APP_URL=http://localhost:3000
